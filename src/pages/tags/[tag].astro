---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EssayCard from "../../components/EssayCard.astro";
import NoteCard from "../../components/NoteCard.astro";
import { getAllPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const all = await getAllPosts();
  const tags = new Map<string, typeof all>();
  for (const post of all) {
    for (const tag of post.data.tags) {
      const list = tags.get(tag) ?? [];
      list.push(post);
      tags.set(tag, list);
    }
  }
  return Array.from(tags.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: { tag, posts }
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`所有标签为 #${tag} 的文章。`}>
  <section class="section hero">
    <div>
      <p class="eyebrow">Tag · {posts.length} 篇</p>
      <h1 class="hero-display">#{tag}</h1>
      <p class="lead">这里是所有打了 <code>#{tag}</code> 标签的文章，包含随笔和笔记。</p>
    </div>
  </section>

  <section class="section band">
    <div class="card-grid">
      {posts.map((post) =>
        post.kind === "essay" ? (
          <EssayCard post={post} />
        ) : (
          <NoteCard post={post} />
        )
      )}
    </div>
  </section>
</BaseLayout>
