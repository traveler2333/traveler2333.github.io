---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="项目 | Traveler2333">
  <section class="section hero">
    <div>
      <p class="eyebrow">Projects</p>
      <h1>项目</h1>
      <p class="lead">这里放值得持续迭代的代码实验、学习项目和可视化结果。</p>
    </div>
  </section>

  <section class="section band">
    <div class="project-grid">
      <a class="project-card" href="https://github.com/traveler2333">
        <div>
          <span class="post-meta">Active</span>
          <h3>PPO CartPole</h3>
          <p>强化学习入门实验，包含训练、对比和可视化输出。</p>
        </div>
        <div class="tag-list">
          <span class="tag">Python</span>
          <span class="tag">PyTorch</span>
          <span class="tag">RL</span>
        </div>
      </a>
      <a class="project-card" href="https://github.com/traveler2333">
        <div>
          <span class="post-meta">Growing</span>
          <h3>Learning Notes</h3>
          <p>把学习中的小结、坑点和理解过程沉淀成可检索文章。</p>
        </div>
        <div class="tag-list">
          <span class="tag">Blog</span>
          <span class="tag">Notes</span>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
