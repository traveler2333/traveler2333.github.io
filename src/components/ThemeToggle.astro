---
// Three-state theme toggle: light / dark / system. Persists to localStorage.
// Initial DOM state is set by an inline script in BaseLayout to avoid a flash.
---

<button
  class="icon-btn theme-toggle"
  type="button"
  data-theme-toggle
  aria-label="切换主题"
  title="切换主题（浅色 / 深色 / 跟随系统）"
>
  <svg
    class="icon-sun"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  <svg
    class="icon-moon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
  <svg
    class="icon-system"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="3" y="4" width="18" height="13" rx="2"></rect>
    <path d="M8 21h8M12 17v4"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    position: relative;
  }
  .theme-toggle svg {
    position: absolute;
    transition:
      opacity var(--duration-base) var(--easing),
      transform var(--duration-base) var(--easing);
    opacity: 0;
    transform: rotate(-20deg) scale(0.8);
  }
  .theme-toggle[data-mode="light"] .icon-sun,
  .theme-toggle[data-mode="dark"] .icon-moon,
  .theme-toggle[data-mode="system"] .icon-system {
    opacity: 1;
    transform: rotate(0) scale(1);
  }
</style>

<script>
  type Mode = "light" | "dark" | "system";
  const KEY = "t2333-theme";

  const apply = (mode: Mode) => {
    const html = document.documentElement;
    html.classList.add("theme-transitioning");
    if (mode === "system") {
      html.removeAttribute("data-theme");
    } else {
      html.setAttribute("data-theme", mode);
    }
    window.setTimeout(() => html.classList.remove("theme-transitioning"), 320);
    document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]").forEach(
      (btn) => btn.setAttribute("data-mode", mode)
    );
    window.dispatchEvent(
      new CustomEvent("themechange", { detail: { mode } })
    );
  };

  const read = (): Mode => {
    try {
      const stored = localStorage.getItem(KEY) as Mode | null;
      if (stored === "light" || stored === "dark" || stored === "system") {
        return stored;
      }
    } catch {}
    return "system";
  };

  const next = (mode: Mode): Mode =>
    mode === "light" ? "dark" : mode === "dark" ? "system" : "light";

  apply(read());

  document.addEventListener("click", (event) => {
    const target = event.target as HTMLElement | null;
    const btn = target?.closest<HTMLButtonElement>("[data-theme-toggle]");
    if (!btn) return;
    const current = read();
    const upcoming = next(current);
    try {
      localStorage.setItem(KEY, upcoming);
    } catch {}
    apply(upcoming);
  });

  if (window.matchMedia) {
    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        if (read() === "system") apply("system");
      });
  }
</script>
