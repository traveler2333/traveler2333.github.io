---
import "../styles/global.css";

const {
  title = "Traveler2333",
  description = "记录编程、强化学习、Python 和一些持续发生的思考。"
} = Astro.props;

const nav = [
  { href: "/", label: "首页" },
  { href: "/blog/", label: "文章" },
  { href: "/projects/", label: "项目" },
  { href: "/about/", label: "关于" }
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav" aria-label="主导航">
          <a class="brand" href="/">
            <span class="brand-mark" aria-hidden="true">T</span>
            <span>Traveler2333</span>
          </a>
          <div class="nav-links">
            {nav.map((item) => (
              <a
                href={item.href}
                aria-current={currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href)) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))}
          </div>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="footer-inner">
          <span>Traveler2333</span>
          <span>Built with Astro, deployed on GitHub Pages.</span>
        </div>
      </footer>
    </div>
  </body>
</html>
